{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "CMake: Configure CryptoForge (GCC)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "-S",
                "${workspaceFolder}",
                "-B",
                "${workspaceFolder}/build",
                "-G",
                "MinGW Makefiles",
                "-DCMAKE_BUILD_TYPE=Debug",
                "-DCMAKE_C_COMPILER=C:/msys64/mingw64/bin/gcc.exe",
                "-DCF_BUILD_TESTS=ON"
            ],
            "group": "build",
            "problemMatcher": [
                "$msCompile",
                "$gcc"
            ],
            "detail": "Configure CryptoForge with CMake using GCC"
        },
        {
            "label": "CMake: Build CryptoForge",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "${workspaceFolder}/build",
                "--config",
                "Debug"
            ],
            "dependsOn": "CMake: Configure CryptoForge (GCC)",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$msCompile",
                "$gcc"
            ],
            "detail": "Build CryptoForge using CMake"
        },
        {
            "label": "CMake: Build & Wait for Executable",
            "type": "shell",
            "dependsOn": "CMake: Build CryptoForge",
            "command": "cmd",
            "args": [
                "/c",
                "if exist \"${workspaceFolder}/build/tests/cf_tests.exe\" (exit 0) else (timeout /t 1 & exit 0)"
            ],
            "problemMatcher": [],
            "detail": "Ensures cf_tests.exe exists before launching"
        }
    ]
}