{
    "tasks": [
        {
            "type": "cppbuild",
            "label": "C/C++: gcc.exe build active file",
            "command": "C:\\msys64\\mingw64\\bin\\gcc.exe",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "${workspaceFolder}/crypto/cipher/aes/*.c",
                "${workspaceFolder}/crypto/hash/sha/*.c",
                "${workspaceFolder}/crypto/hash/sha/keccak/*.c",
                "${workspaceFolder}/crypto/hash/md/*.c",
                "${workspaceFolder}/crypto/mac/*.c",
                "${workspaceFolder}/crypto/kdf/*.c",
                "${workspaceFolder}/crypto/enc/*.c",
                "${workspaceFolder}/crypto/evp/*.c",
                "${workspaceFolder}/utils/*.c",
                "${workspaceFolder}/demo/*.c",
                "-o",
                "${workspaceFolder}/bin/run_all_demos.exe"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Task generated by Debugger."
        }
    ],
    "version": "2.0.0"
